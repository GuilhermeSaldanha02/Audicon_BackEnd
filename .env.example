# Audicon API — variáveis de ambiente
# Copie este arquivo para `.env` na raiz do projeto e preencha os valores reais.
# Nunca comite o `.env` real.
# O schema é validado no bootstrap (src/common/config/env.schema.ts);
# variáveis faltantes ou inválidas impedem o start da aplicação.

# --- Aplicação ---
# Ambiente. Valores aceitos: development | test | production. Default: development.
NODE_ENV=development
# Porta HTTP da API. Default: 3000.
PORT=3000
# Nível do logger pino (opcional). Valores: fatal|error|warn|info|debug|trace|silent.
# Default por ambiente: production=info, development=debug, test=silent.
LOG_LEVEL=

# --- Banco de dados (PostgreSQL) ---
# Host do Postgres. Em dev local: localhost. Em Docker Compose: db (nome do serviço).
DB_HOST=localhost
# Porta do Postgres.
DB_PORT=5432
# Usuário do Postgres.
DB_USERNAME=postgres
# Senha do Postgres. Não deixar vazio — a aplicação falhará no bootstrap.
DB_PASSWORD=__SET_ME__
# Nome do database.
DB_DATABASE=audicon

# --- Autenticação (JWT) ---
# Segredo de assinatura. Mínimo 16 caracteres. Gerar com `openssl rand -base64 48`.
JWT_SECRET=__SET_ME__
# Tempo de expiração do token (ex.: 3600s, 1h, 7d).
JWT_EXPIRATION=1h

# --- CORS ---
# Origens permitidas, separadas por vírgula (consumido em main.ts a partir da T-01).
# Ex.: http://localhost:4173,https://app.audicon.com.br
CORS_ORIGINS=http://localhost:4173

# --- Google Gemini (IA) ---
# Chave da API do Gemini. Em produção é obrigatória (validada em IaService).
# Em dev/test pode ficar vazia; IaService cai em modo mock.
GEMINI_API_KEY=
# Endpoint da API (opcional). Default: https://generativelanguage.googleapis.com/v1
GEMINI_API_ENDPOINT=
# Modelo a usar (opcional). Default: gemini-1.5-pro
GEMINI_MODEL=
# Timeout em milissegundos para a chamada ao Gemini (opcional). Default: 15000.
# Min 1000, max 60000. Acima desse limite, a request retorna 502.
GEMINI_TIMEOUT_MS=

# --- Resend (e-mail) ---
# Chave da API do Resend (opcional). Sem ela, MailService opera em modo mock.
RESEND_API_KEY=
# E-mail remetente. Default: onboarding@resend.dev (sandbox). Em prod usar domínio verificado.
RESEND_FROM_EMAIL=
# Segredo do webhook Resend (svix). Sem ele, POST /webhooks/resend aceita qualquer payload (dev only).
RESEND_WEBHOOK_SECRET=

# --- Z-API (WhatsApp) ---
# Sem qualquer um destes, WhatsappService opera em modo mock.
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
